                </div>
            </div>

            <!-- زر القائمة للهواتف -->
            <div class="mobile-menu-btn">
                <i class="fa-solid fa-bars"></i>
            </div>
        </div>
    </nav>
```

### 2. التعديل في ملف `style.css`
ابحث عن استعلام الوسائط للهواتف المحمولة في نهاية ملف الـ CSS (وهو `@media (max-width: 768px)`).
قم **بحذف** كود الإخفاء القديم، واستبدل كامل قسم الـ `@media` بهذا الكود:

```css
/* التجاوب مع الشاشات (Responsive) والقائمة المنسدلة */
@media (max-width: 768px) {
    .menu-wrapper {
        position: absolute;
        top: 100%;
        right: 0;
        width: 100%;
        background-color: var(--bg-color);
        flex-direction: column;
        padding: 20px;
        box-shadow: 0 10px 15px rgba(0,0,0,0.1);
        /* إعدادات الأنيميشن للإخفاء والظهور */
        transform: translateY(-20px);
        opacity: 0;
        visibility: hidden;
        transition: var(--transition);
        display: flex;
        gap: 20px;
        z-index: 999;
    }

    /* الكلاس الذي سنضيفه بالجافاسكريبت لفتح القائمة */
    .menu-wrapper.active {
        transform: translateY(0);
        opacity: 1;
        visibility: visible;
    }

    .nav-links {
        flex-direction: column;
        text-align: center;
        gap: 15px;
    }

    .nav-buttons {
        flex-direction: column;
        width: 100%;
    }

    .mobile-menu-btn {
        display: block;
    }

    .hero-content h1 {
        font-size: 2.5rem;
    }
    .hero-buttons {
        flex-direction: column;
    }
    .tab-flex {
        flex-direction: column;
    }
    .tab-image {
        display: none;
    }
}

/* في الشاشات الكبيرة، تأكد أن الحاوية تُعرض بشكل طبيعي بجانب اللوجو */
@media (min-width: 769px) {
    .menu-wrapper {
        display: flex;
        align-items: center;
        gap: 30px;
    }
}
```

### 3. التعديل في ملف `script.js`
أضف هذا الكود في نهاية ملف الجافاسكريبت لتفعيل وظيفة النقر على الزر، وتغيير شكل الأيقونة من (☰) إلى (✕) عند الفتح، مع إغلاق القائمة تلقائياً عند الضغط على أحد الروابط.

```javascript
// 6. قائمة الموبايل المنسدلة (Mobile Dropdown Menu)
const mobileMenuBtn = document.querySelector('.mobile-menu-btn');
const menuWrapper = document.querySelector('.menu-wrapper');
const menuIcon = document.querySelector('.mobile-menu-btn i');

mobileMenuBtn.addEventListener('click', () => {
    // التبديل بين فتح وإغلاق القائمة
    menuWrapper.classList.toggle('active');
    
    // تغيير الأيقونة بين القائمة (bars) وعلامة (X)
    if (menuWrapper.classList.contains('active')) {
        menuIcon.classList.remove('fa-bars');
        menuIcon.classList.add('fa-xmark');
    } else {
        menuIcon.classList.remove('fa-xmark');
        menuIcon.classList.add('fa-bars');
    }
});

// إغلاق القائمة المنسدلة تلقائياً عند الضغط على أي رابط (لتحسين تجربة المستخدم)
const mobileNavLinks = document.querySelectorAll('.nav-links a');
mobileNavLinks.forEach(link => {
    link.addEventListener('click', () => {
        menuWrapper.classList.remove('active');
        menuIcon.classList.remove('fa-xmark');
        menuIcon.classList.add('fa-bars');
    });
});
```

بهذه التعديلات، أصبح لديك الآن قائمة موبايل منسدلة (Dropdown) تنزل بحركة سلسة (Fade & Slide Down)، وتُغلق بشكل ذكي وتلقائي بمجرد تنقل المستخدم بين أقسام الموقع!

